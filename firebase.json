{
  "apphosting": [
    {
      "backendId": "studio",
      "source": ".",
      "ignore": [
        "firebase.json",
        ".git",
        ".firebase",
        ".vscode",
        ".env*",
        "service-account-key.json",
        "*.log",
        ".next",
        "**/node_modules/**",
        "*.zip",
        "tsconfig.tsbuildinfo"
      ],
      "frameworksBackend": {
        "region": "us-central1"
      }
    }
  ],
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": [
        "npm --prefix functions run build"
      ]
    }
  ]
}